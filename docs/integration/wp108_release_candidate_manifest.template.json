  "rubric": [
    {
      "id": "semantic_faithfulness",
      "name": "Semantic faithfulness",
      "scale": "0-4 integer or decimal score",
      "pass_threshold": 3.0,
      "anchors": [
        {
          "score": 0,
          "description": "Major scientific meaning is absent or contradicted."
        },
        {
          "score": 3,
          "description": "Core scientific relationships, variables, and labels are preserved with only minor omissions."
        },
        {
          "score": 4,
          "description": "Scientific meaning, variables, labels, and key relationships are faithfully represented."
        }
      ]
    },
    {
      "id": "visual_legibility",
      "name": "Visual legibility",
      "scale": "0-4 integer or decimal score",
      "pass_threshold": 3.0,
      "anchors": [
        {
          "score": 0,
          "description": "The output is unreadable or visually incoherent."
        },
        {
          "score": 3,
          "description": "The output is readable with minor layout, spacing, or labeling issues."
        },
        {
          "score": 4,
          "description": "The output is clear, well organized, and suitable for detailed scientific review."
        }
      ]
    },
    {
      "id": "structural_coherence",
      "name": "Structural coherence",
      "scale": "0-4 integer or decimal score",
      "pass_threshold": 3.0,
      "anchors": [
        {
          "score": 0,
          "description": "The diagram or plot structure prevents interpretation of the intended relationship."
        },
        {
          "score": 3,
          "description": "The structural organization communicates the intended relationship with minor ambiguity."
        },
        {
          "score": 4,
          "description": "The structural organization is coherent, complete, and aligned to the intended relationship."
        }
      ]
    },
    {
      "id": "style_and_labeling",
      "name": "Style and labeling",
      "scale": "0-4 integer or decimal score",
      "pass_threshold": 3.0,
      "anchors": [
        {
          "score": 0,
          "description": "Labels, typography, or style choices make the output unsuitable for review."
        },
        {
          "score": 3,
          "description": "Labels and style choices are usable with minor polish issues."
        },
        {
          "score": 4,
          "description": "Labels, typography, and style choices are consistent, readable, and review-ready."
        }
      ]
    },
    {
      "id": "artifact_completeness",
      "name": "Artifact completeness",
      "scale": "0-4 integer or decimal score",
      "pass_threshold": 3.0,
      "anchors": [
        {
          "score": 0,
          "description": "Required output or provenance artifacts are missing."
        },
        {
          "score": 3,
          "description": "Required artifacts are present and traceable with minor documentation gaps."
        },
        {
          "score": 4,
          "description": "Required artifacts, provenance, and recovery evidence are complete and internally consistent."
        }
      ]
    }
